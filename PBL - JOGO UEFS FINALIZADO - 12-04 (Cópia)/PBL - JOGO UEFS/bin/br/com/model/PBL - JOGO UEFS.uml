              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_erqkAibuEfG54uhjZS0hZw" name="calcularScore" specification="_eo3HoCbuEfG54uhjZS0hZw">
                <ownedParameter xmi:id="_erqkAybuEfG54uhjZS0hZw" name="jogador" type="_ehQq0CbuEfG54uhjZS0hZw"/>
                <ownedParameter xmi:id="_erqkBCbuEfG54uhjZS0hZw" direction="return">
                  <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
                </ownedParameter>
                <language>java</language>
                <body>List&lt;Subjects> materiaSubjects = jogador.getDisciplinas();
		double formula;
		double somaCargaHoraria = 0.0;
		double somaNotas = 0.0;
		double somaChNota = 0.0;
		double mediaFinal;

		
		for(Subjects element: materiaSubjects) {
			somaCargaHoraria = somaCargaHoraria + element.getCargaHorariaInt();
			for(double i: element.getNotasProvasList()) {
				somaNotas = somaNotas + i;
			}
			mediaFinal = somaNotas / element.getNumeroProvasInt();
			formula = (element.getCargaHorariaInt()*element.getCargaHorariaInt());
			somaChNota = somaChNota + formula;
		}
		scoreDouble = somaChNota / somaCargaHoraria;
		return scoreDouble;
		
	</body>
              </ownedBehavior>
