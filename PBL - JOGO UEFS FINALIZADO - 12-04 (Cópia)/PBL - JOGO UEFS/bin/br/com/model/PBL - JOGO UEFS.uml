              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_erqkACbuEfG54uhjZS0hZw" name="somaDinheiro" specification="_ehn3MCbuEfG54uhjZS0hZw">
                <ownedParameter xmi:id="_erqkASbuEfG54uhjZS0hZw" name="valor">
                  <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
                </ownedParameter>
                <language>java</language>
                <body>dinheiroDouble = dinheiroDouble + valor;
	</body>
